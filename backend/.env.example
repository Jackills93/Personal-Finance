# Connection string Postgres di Supabase — Settings > Database > Connection string
# Usa il pooler "Transaction" (porta 6543) per compatibilità con Render free tier.
# Prefisso postgresql+psycopg:// (driver psycopg3, non postgresql:// puro).
DATABASE_URL=postgresql+psycopg://postgres.xxxxx:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Origini consentite per CORS, separate da virgola.
# In locale: l'origine da cui apri frontend/index.html (es. con un live server).
# In produzione: l'URL del progetto su Vercel.
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# Bot Telegram (opzionale — senza queste due var l'app funziona normalmente,
# semplicemente niente notifiche e il webhook ignora ogni messaggio).
# Token: crealo con @BotFather su Telegram (/newbot).
# Chat ID: il tuo id numerico, es. scrivendo al bot e leggendo
# https://api.telegram.org/bot<TOKEN>/getUpdates, oppure chiedendolo a @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Password unica condivisa per proteggere l'accesso ai dati (opzionale — se
# non impostata, l'API resta aperta come oggi). Richiesta su ogni endpoint
# dati (categories/movements/recurring/accounts/persons) via header
# X-App-Password. Il webhook Telegram e /health non la richiedono.
APP_PASSWORD=
