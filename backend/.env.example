# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
# Supabase: Settings > Database > Connection string > Connection pooling
# (modalità Transaction, porta 6543). Cambia il prefisso in postgresql+psycopg://
#
# Railway PostgreSQL: usa la variabile DATABASE_URL iniettata automaticamente
# dal servizio PostgreSQL di Railway (non serve cambiarla a mano).
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname

# ─────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────
# Origini consentite, separate da virgola.
# Locale:     http://localhost:5500,http://127.0.0.1:5500
# Produzione: URL del frontend su Vercel
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500

# ─────────────────────────────────────────────
# SICUREZZA
# ─────────────────────────────────────────────
# Password condivisa per proteggere tutti gli endpoint dati.
# Impostala anche su Vercel → Settings → Environment Variables.
APP_PASSWORD=

# ─────────────────────────────────────────────
# BOT TELEGRAM (opzionale)
# ─────────────────────────────────────────────
# Senza queste variabili l'app funziona normalmente — niente notifiche.
#
# TELEGRAM_BOT_TOKEN : token del bot da @BotFather (/newbot)
# TELEGRAM_WEBHOOK_SECRET : stringa segreta a piacere (es. da `openssl rand -hex 16`).
#                      Va passata a Telegram con &secret_token=... quando si registra
#                      il webhook: così solo Telegram può chiamare l'endpoint /telegram/webhook.
# TELEGRAM_CHAT_ID   : chat ID numerico del primo utente
#                      (scrivi al bot, poi apri /bot<TOKEN>/getUpdates)
# TELEGRAM_CHAT_ID_NAME : nome da mostrare nell'app per il primo utente
#                         (se vuoto, viene usato il first_name Telegram)
#
# Stesse variabili _GRETA per un secondo utente (facoltativi)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_CHAT_ID=
TELEGRAM_CHAT_ID_NAME=
TELEGRAM_CHAT_ID_GRETA=
TELEGRAM_CHAT_ID_GRETA_NAME=
